# NextHire AI - Environment Variables Template
# Copy this file to '.env' and fill in your details

# Database Connection URI (Defaults to SQLite for local development)
DATABASE_URL=sqlite:///./nexthire.db

# Google Gemini API Key (Required for AI features. Get one from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend Service Configuration
PORT=8000
ENV=development

# Frontend Service Configuration (React/Vite local development url)
# Note: For deployment, set VITE_API_BASE_URL to your Render web service URL.
VITE_API_BASE_URL=http://localhost:8000
